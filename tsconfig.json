{
    "compilerOptions": {
        "target": "ES6",
        "module": "commonjs",
        "strict": true,
        "types": [
            "node",
            "jest"
        ],
        "rootDir": ".",
        "outDir": "build",
        "sourceMap": true,
        "esModuleInterop": true
    },
    "include": [
        "src/**/*.ts",
        "tests/**/*.ts",
        "jest.config.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}